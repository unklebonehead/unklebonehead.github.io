    <item>
      <title>Online Freedom Starts With Your Device</title>
      <link>//localhost:1313/posts/online-freedom-starts-with-your-device/</link>
      <pubDate>Sat, 16 Mar 2024 20:25:51 -0400</pubDate>
      <guid>//localhost:1313/posts/online-freedom-starts-with-your-device/</guid>
